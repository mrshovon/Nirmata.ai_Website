body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
}

/* Hero Section */
.hero-section {
    height: 100vh;

    /* 🔥 Replace this later */
    background: url('../Assets/images/bg.jpeg') no-repeat center center/cover;

    position: relative;
}

/* Optional overlay */
.hero-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.6);
}

/* Content */
.hero-section .content {
    position: relative;
    z-index: 2;
}

.brand-name {
    font-size: 60px;
    font-weight: 600;
    letter-spacing: 2px;
}

.tagline {
    font-size: 16px;
    color: #555;
}

/* Sections */
.section-space {
    padding: 100px 0;
    text-align: center;
    background: #f8f9fa;
    border-bottom: 1px solid #eee;
}